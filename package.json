{
  "name": "kotonoha",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @kotonoha/web dev",
    "dev:desktop": "pnpm --filter @kotonoha/desktop tauri dev",
    "build:web": "pnpm --filter @kotonoha/web build",
    "build:desktop": "pnpm --filter @kotonoha/desktop tauri build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "better-sqlite3", "esbuild"]
  }
}
